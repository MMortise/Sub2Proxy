# AI assistant workspaces
.claude/
.codex/
.omx/
.agents/

# OS / editor cruft
.DS_Store
*.swp
*~
.vscode/
.idea/

# Build output
/sub2proxy
web/frontend/node_modules/
# Embedded web UI build (web/embed.go embeds web/dist; regenerated by the frontend
# build / Docker). Keep .gitkeep so `//go:embed all:dist` still compiles on a
# fresh clone that hasn't built the frontend yet.
/web/dist/*
!/web/dist/.gitkeep

# Go test & coverage artifacts
*.test
*.out

# Release build output (scripts/release.sh) — published to GitHub Releases, not git
/dist-release/

# Runtime data (node cache, sqlite) — regenerated at runtime
/data/

# Secrets & local config — config.yaml holds subscription tokens and the auth key
config.yaml
.env
.env.*
